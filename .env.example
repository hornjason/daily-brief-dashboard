# Required — Red Hat Customer Portal API token
# Get yours at: https://access.redhat.com/management/api
REDHAT_OFFLINE_TOKEN=your_offline_token_here

# AI briefs — defaults ship in the container image (shared GCP project + service account).
# Override only if you want to use your own GCP project:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GEMINI_SERVICE_ACCOUNT_KEY=eyJ0eXAi...   (base64: macOS: base64 -i key.json | Linux: base64 -w0 key.json)

# Optional — Gemini model and region (defaults shown — already set in the container image)
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_LOCATION=us-east1

# Optional — Intelligence cache TTLs (BKL-TOKEN-02, tiered)
# Company intelligence changes often (leadership, earnings, M&A) → 14d default.
# Industry analysis is macro-level and stable → 30d default.
# Skip regeneration only fires when BOTH are still fresh.
# INTELLIGENCE_COMPANY_TTL_DAYS=14
# INTELLIGENCE_INDUSTRY_TTL_DAYS=30

# Optional — Google Drive link to shared gcp-oauth.keys.json (shown in setup wizard)
# Most users don't need to change this — the default points to the shared keys file
# VITE_OAUTH_KEYS_DRIVE_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view

# Optional — push notifications via ntfy.sh
# NTFY_TOPIC=asa-command-center

# Optional — server port (default: 7777)
# PORT=7777

# Optional — Salesforce pipeline Google Sheet ID (auto-configured by wizard)
# PIPELINE_FILE_ID=your_sheet_id

# Optional — Tableau Cloud base URL for CCSP session check
# TABLEAU_BASE_URL=https://prod-useast1.online.tableau.com

# Optional — additional territory sheet URLs shown as quick-fill options in the wizard.
# Built-in sheets are pre-loaded automatically; add extras here comma-separated.
# WIZARD_SEED_SHEETS=https://docs.google.com/spreadsheets/d/...

# --- Path overrides (set automatically in container — most users ignore these) ---
# GOOGLE_OAUTH_KEYS=/absolute/path/to/gcp-oauth.keys.json
# GMAIL_TOKEN=/absolute/path/to/.gmail-token.json
# GDRIVE_TOKEN=/absolute/path/to/.gdrive-server-credentials.json
